{
    "name": "leek/filament-header-filters",
    "description": "Inline header filter components for Filament tables — attach any BaseFilter to a column header.",
    "keywords": [
        "leek",
        "laravel",
        "filament",
        "filamentphp",
        "tables",
        "filters",
        "header-filters"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Chris Jones",
            "email": "leeked@gmail.com",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/leek/filament-header-filters/issues",
        "source": "https://github.com/leek/filament-header-filters"
    },
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0 || ^5.0",
        "spatie/laravel-package-tools": "^1.15"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
        "pestphp/pest": "^3.0 || ^4.0",
        "pestphp/pest-plugin-laravel": "^3.0 || ^4.0"
    },
    "autoload": {
        "psr-4": {
            "Leek\\FilamentHeaderFilters\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Leek\\FilamentHeaderFilters\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "test": "vendor/bin/pest",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Leek\\FilamentHeaderFilters\\FilamentHeaderFiltersServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
